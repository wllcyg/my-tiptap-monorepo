{
  "name": "@myorg/tiptap-lib",
  "version": "0.1.0",
  "description": "Vue 3 Tiptap rich text editor with optional Tailwind default toolbar and full slot customization",
  "author": "Your Name",
  "license": "MIT",
  "keywords": [
    "tiptap",
    "vue3",
    "editor",
    "rich-text",
    "tailwind"
  ],
  "main": "./dist/tiptap-lib.umd.cjs",
  "module": "./dist/tiptap-lib.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "development": "./src/index.ts",
        "default": "./dist/tiptap-lib.js"
      },
      "require": "./dist/tiptap-lib.umd.cjs",
      "types": "./src/index.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "peerDependencies": {
    "@tiptap/core": "^2.2.0",
    "@tiptap/starter-kit": "^2.2.0",
    "@tiptap/vue-3": "^2.2.0",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.0.3",
    "@vitejs/plugin-vue": "^5.2.4",
    "autoprefixer": "^10.4.23",
    "naive-ui": "^2.43.2",
    "postcss": "^8.5.6",
    "sass-embedded": "^1.97.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vfonts": "^0.0.3",
    "vite": "^5.4.21",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "@vicons/ionicons5": "^0.13.0"
  }
}