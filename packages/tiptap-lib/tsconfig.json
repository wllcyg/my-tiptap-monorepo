{
  "extends": "../../packages/typescript-config/base.json",
  "compilerOptions": {
    "composite": true, // 必须为 true（复合项目必需）
    "tsBuildInfoFile": "./dist/.tsbuildinfo", // 增量编译信息存放位置（必须指定）
    "incremental": true, // 必须为 true，不能禁用

    "outDir": "dist",
    "rootDir": "src",

    "declaration": true, // 必须为 true（生成 .d.ts）
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
