# 腾讯云 COS 配置
# 复制此文件为 .env.local 并填入真实配置

# 存储桶名称（格式：BucketName-APPID）
VITE_COS_BUCKET=your-bucket-1234567890

# 存储桶所在地域
# 可选值：ap-beijing, ap-shanghai, ap-guangzhou, ap-chengdu, ap-nanjing, ap-chongqing 等
VITE_COS_REGION=ap-guangzhou

# 上传文件的目录前缀（可选）
VITE_COS_PREFIX=editor-images

# 注意：
# 1. 不要将真实的密钥提交到代码仓库
# 2. 临时密钥应该通过后端接口获取
# 3. 本地开发可以使用 .env.local（已在 .gitignore 中）
